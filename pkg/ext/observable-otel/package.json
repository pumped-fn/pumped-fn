{
  "name": "@pumped-fn/lite-extension-observable-otel",
  "version": "2.0.0",
  "private": false,
  "description": "OpenTelemetry sink adapter for @pumped-fn/lite-extension-observable",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@pumped-fn/lite-extension-observable": "^0.4.0 || ^1.0.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "catalog:",
    "@pumped-fn/lite": "workspace:*",
    "@pumped-fn/lite-extension-observable": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "pumped-fn",
    "observable",
    "opentelemetry",
    "otel",
    "extension"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "directory": "pkg/ext/observable-otel",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  }
}
