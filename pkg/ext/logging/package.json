{
  "name": "@pumped-fn/lite-extension-logging",
  "version": "0.3.0",
  "private": false,
  "description": "Execution-scoped logging extension for @pumped-fn/lite with tag-injected sinks",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@pumped-fn/lite": "^3.1.0"
  },
  "devDependencies": {
    "@pumped-fn/lite": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "pumped-fn",
    "logging",
    "logger",
    "extension"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "directory": "pkg/ext/logging",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  }
}
