{
  "name": "@pumped-fn/sdk",
  "version": "2.0.0",
  "private": false,
  "description": "Agent workflow and app helpers for @pumped-fn/lite",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./agent": {
      "import": {
        "types": "./dist/agent.d.mts",
        "default": "./dist/agent.mjs"
      },
      "require": {
        "types": "./dist/agent.d.cts",
        "default": "./dist/agent.cjs"
      }
    },
    "./session": {
      "import": {
        "types": "./dist/session.d.mts",
        "default": "./dist/session.mjs"
      },
      "require": {
        "types": "./dist/session.d.cts",
        "default": "./dist/session.cjs"
      }
    },
    "./validation": {
      "import": {
        "types": "./dist/validation.d.mts",
        "default": "./dist/validation.mjs"
      },
      "require": {
        "types": "./dist/validation.d.cts",
        "default": "./dist/validation.cjs"
      }
    },
    "./sandbox": {
      "import": {
        "types": "./dist/sandbox.d.mts",
        "default": "./dist/sandbox.mjs"
      },
      "require": {
        "types": "./dist/sandbox.d.cts",
        "default": "./dist/sandbox.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "PATTERNS.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@pumped-fn/lite": "^5.0.0"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:",
    "@pumped-fn/lite-extension-suspense": "workspace:^"
  },
  "devDependencies": {
    "@pumped-fn/lite": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@valibot/to-json-schema": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "directory": "pkg/sdk/core",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  }
}
