{
  "name": "@pumped-fn/sdk-pi",
  "version": "2.0.0",
  "private": false,
  "description": "In-process pi-ai model provider for @pumped-fn/sdk",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@pumped-fn/sdk": "^3.0.0",
    "@pumped-fn/lite": "^5.0.0"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "catalog:"
  },
  "devDependencies": {
    "@pumped-fn/sdk": "workspace:*",
    "@pumped-fn/lite": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "directory": "pkg/sdk/pi",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  }
}
