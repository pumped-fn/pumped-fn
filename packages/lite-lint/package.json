{
  "name": "@pumped-fn/lite-lint",
  "version": "0.1.0",
  "description": "Static anti-pattern scanner for @pumped-fn/lite and @pumped-fn/lite-react",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "pumped-lite-lint": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown --config-loader tsx",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "directory": "packages/lite-lint",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  },
  "keywords": [
    "pumped-fn",
    "lite",
    "lint",
    "static-analysis"
  ],
  "license": "MIT"
}
