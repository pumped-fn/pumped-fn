{
  "name": "@pumped-fn/lite-legend",
  "version": "0.0.0-poc",
  "description": "Legend-State v3 bridge for @pumped-fn/lite (POC)",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "typecheck:full": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run"
  },
  "peerDependencies": {
    "@legendapp/state": "^3.0.0-beta.0",
    "@pumped-fn/lite": ">=1.4.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@legendapp/state": "catalog:",
    "@pumped-fn/lite": "workspace:*",
    "@pumped-fn/lite-react": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "^18.3.27",
    "@vitest/coverage-v8": "catalog:",
    "global-jsdom": "^29.0.0",
    "jsdom": "^27.3.0",
    "react": "^18.3.1",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
