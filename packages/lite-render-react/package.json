{
  "name": "@pumped-fn/lite-render-react",
  "version": "0.1.0",
  "description": "React adapter that lowers a verified @pumped-fn/lite-render-core spec to React over a Lite scope",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown --config-loader tsx",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@pumped-fn/lite-render-core": "workspace:*"
  },
  "peerDependencies": {
    "@pumped-fn/lite-react": "^2.3.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@pumped-fn/lite": "workspace:*",
    "@pumped-fn/lite-react": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "directory": "packages/lite-render-react",
    "url": "git+https://github.com/pumped-fn/pumped-fn.git"
  },
  "keywords": [
    "render-contract",
    "json-spec",
    "catalog",
    "react",
    "renderer",
    "pumped-fn",
    "lite"
  ],
  "license": "MIT"
}
