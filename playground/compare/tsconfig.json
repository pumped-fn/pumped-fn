{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "jsx": "react-jsx",
    "paths": {
      "@pumped-fn/lite": ["../../pkg/core/lite/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vite/client", "vitest/globals"]
  },
  "include": ["cases", "sandbox", "src", "vite.config.ts"]
}
