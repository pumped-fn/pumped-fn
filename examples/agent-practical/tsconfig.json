{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "typeRoots": ["./node_modules/@types", "../../pkg/core/lite/node_modules/@types"],
    "paths": {
      "@pumped-fn/agent-sdk": ["../../pkg/agent/core/src/index.ts"],
      "@pumped-fn/agent-sdk-claude": ["../../pkg/agent/claude/src/index.ts"],
      "@pumped-fn/agent-sdk-codex": ["../../pkg/agent/codex/src/index.ts"],
      "@pumped-fn/agent-sdk-just-bash": ["../../pkg/agent/bash/src/index.ts"],
      "@pumped-fn/agent-sdk-test": ["../../pkg/agent/test/src/index.ts"],
      "@pumped-fn/lite-extension-suspense": ["../../pkg/ext/suspense/src/index.ts"],
      "@pumped-fn/lite": ["../../pkg/core/lite/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
