GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repository
GITHUB_LABEL=agent:triage
GITHUB_PUBLICATION_TIMEOUT_MS=30000
CONTROL_DATABASE_URL=postgres://triage:triage@localhost:5433/issue_triage
TARGET_DATABASE_URL=postgres://readonly:readonly@localhost:5432/production
REPOSITORY_ROOT=/workspace/repository
CODE_PATH=src
CODE_QUERY=checkout
DATABASE_QUERY=SELECT queryid, calls, mean_exec_time, rows FROM pg_stat_statements ORDER BY mean_exec_time DESC LIMIT 20
VICTORIA_URL=http://localhost:8428
VICTORIA_QUERY=histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))
MODEL_PROVIDER=anthropic
MODEL_ID=claude-sonnet-4-5
MODEL_THINKING=high
MODEL_API_KEY_ENV=ANTHROPIC_API_KEY
