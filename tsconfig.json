{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@pumped-fn/sdk": ["pkg/sdk/core/src/index.ts"],
      "@pumped-fn/sdk-test": ["pkg/sdk/test/src/index.ts"],
      "@pumped-fn/lite": ["pkg/core/lite/src/index.ts"],
      "@pumped-fn/lite/*": ["pkg/core/lite/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "tasks"]
}
